classDiagram
    class User {
        +String userId
        +String email
        +String name
        +String status
        +signUp()
        +login()
        +updateProfile()
    }

    class Admin {
        +manageUser()
        +managePolicy()
        +viewAuditLog()
    }

    class Role {
        +String roleId
        +String roleName
        +List permissions
    }

    class Folder {
        +String folderId
        +String name
        +String ownerId
        +createFolder()
        +moveFile()
    }

    class FileItem {
        +String fileId
        +String fileName
        +String folderId
        +Long size
        +String extension
        +String storagePath
        +upload()
        +download()
        +delete()
    }

    class SharePermission {
        +String permissionId
        +String targetType
        +String permissionType
        +grant()
        +revoke()
        +change()
        +verify()
    }

    class ShareLink {
        +String linkId
        +String token
        +Date expiresAt
        +Boolean active
        +create()
        +expire()
        +validate()
    }

    class Comment {
        +String commentId
        +String content
        +Date createdAt
        +create()
        +update()
        +delete()
    }

    class FileVersion {
        +String versionId
        +Integer versionNo
        +String storagePath
        +Date createdAt
        +restore()
    }

    class ActivityLog {
        +String logId
        +String eventType
        +String ipAddress
        +Date occurredAt
        +record()
        +search()
    }

    class StorageService {
        +saveFile()
        +loadFile()
        +deleteFile()
    }

    class Database {
        +save()
        +find()
        +update()
        +delete()
    }

    class FileUploadControl {
        +upload()
        -verifyUploadPermission()
    }

    class ShareControl {
        +grantShare()
        +revokeShare()
        -verifySharePermission()
    }

    class CommentControl {
        +addComment()
        +updateComment()
        +deleteComment()
        -verifyCommentPermission()
    }

    class VersionControl {
        +restoreVersion()
        -verifyModifyPermission()
    }

    class SearchControl {
        +search()
        -resolveAccessibleScope()
    }

    class AuditLogControl {
        +queryLogs()
        -verifyAdminPermission()
    }

    User <|-- Admin
    User --> Role
    User "1" --> "0..*" FileItem : owns
    Folder "1" --> "0..*" FileItem : contains
    FileItem "1" --> "0..*" SharePermission
    FileItem "1" --> "0..*" ShareLink
    FileItem "1" --> "0..*" Comment
    FileItem "1" --> "1..*" FileVersion
    User "1" --> "0..*" Comment : writes
    User "1" --> "0..*" ActivityLog
    FileItem "1" --> "0..*" ActivityLog
    StorageService --> FileItem
    Database --> User
    Database --> FileItem
    FileUploadControl ..> FileItem
    FileUploadControl ..> FileVersion
    FileUploadControl ..> SharePermission
    FileUploadControl ..> Folder
    FileUploadControl ..> StorageService
    FileUploadControl ..> Database
    FileUploadControl ..> ActivityLog
    ShareControl ..> SharePermission
    ShareControl ..> ShareLink
    ShareControl ..> FileItem
    ShareControl ..> Folder
    ShareControl ..> Database
    ShareControl ..> ActivityLog
    CommentControl ..> Comment
    CommentControl ..> SharePermission
    CommentControl ..> FileItem
    CommentControl ..> Database
    CommentControl ..> ActivityLog
    VersionControl ..> FileVersion
    VersionControl ..> FileItem
    VersionControl ..> SharePermission
    VersionControl ..> StorageService
    VersionControl ..> Database
    VersionControl ..> ActivityLog
    SearchControl ..> FileItem
    SearchControl ..> SharePermission
    SearchControl ..> Folder
    SearchControl ..> Database
    AuditLogControl ..> ActivityLog
    AuditLogControl ..> Admin
    AuditLogControl ..> Role
    AuditLogControl ..> Database
